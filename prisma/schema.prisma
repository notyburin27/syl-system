// This is your Prisma schema file

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
}

model AuthUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // bcrypt hashed
  role      Role     @default(STAFF)
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  documents TransportDocument[]
  jobs      Job[]

  @@index([username])
  @@map("auth_users")
}

model TransportDocument {
  id          String   @id @default(cuid())
  title       String

  // Form fields (19 fields)
  date              DateTime?
  customerName      String?
  booking           String?
  agent             String?
  shipName          String?
  invoice           String?
  containerSize     String?
  containerNumber   String?
  sealNumber        String?
  shipping          String?
  pickupLocation    String?
  returnLocation    String?
  closingTime       DateTime?
  factoryTime       String?
  loadingSlot       String?
  driverName        String?
  vehicleRegistration String?
  phoneNumber       String?
  remarks           String?

  // Metadata
  createdById String
  createdBy   AuthUser @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
  @@index([createdAt])
  @@map("transport_documents")
}

// ==================== Stock Module ====================

model Product {
  id           String     @id @default(cuid())
  name         String
  sellingPrice Float
  image        String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  stockIns  StockIn[]
  stockOuts StockOut[]

  @@index([name])
  @@map("products")
}

model Buyer {
  id        String     @id @default(cuid())
  name      String
  phone     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  stockOuts StockOut[]
  invoices  Invoice[]

  @@index([name])
  @@map("buyers")
}

model StockIn {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  purchasePrice Float
  quantity      Int
  date          DateTime
  note          String?
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([date])
  @@map("stock_ins")
}

model StockOut {
  id           String    @id @default(cuid())
  productId    String
  product      Product   @relation(fields: [productId], references: [id])
  buyerId      String
  buyer        Buyer     @relation(fields: [buyerId], references: [id])
  quantity     Int
  sellingPrice Float
  date         DateTime
  isDelivered  Boolean   @default(false)
  deliveredAt  DateTime?
  invoiceId    String?
  invoice      Invoice?  @relation(fields: [invoiceId], references: [id])
  note         String?
  createdAt    DateTime  @default(now())

  @@index([productId])
  @@index([buyerId])
  @@index([invoiceId])
  @@index([date])
  @@map("stock_outs")
}

model Invoice {
  id          String    @id @default(cuid())
  buyerId     String
  buyer       Buyer     @relation(fields: [buyerId], references: [id])
  totalAmount Float
  isPaid      Boolean   @default(false)
  paidAt      DateTime?
  note        String?
  createdAt   DateTime  @default(now())

  stockOuts StockOut[]

  @@index([buyerId])
  @@index([isPaid])
  @@map("invoices")
}

// ==================== Job Management Module ====================

model Customer {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs        Job[]
  incomeRates RateIncome[]

  @@index([name])
  @@map("customers")
}

model Driver {
  id                  String              @id @default(cuid())
  name                String              @unique
  vehicleNumber       String?
  vehicleRegistration String?
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  bankAccounts DriverBankAccount[]
  jobs         Job[]

  @@index([name])
  @@map("drivers")
}

model DriverBankAccount {
  id          String   @id @default(cuid())
  driverId    String
  driver      Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  bankName    String
  accountNo   String
  accountName String
  createdAt   DateTime @default(now())

  @@index([driverId])
  @@map("driver_bank_accounts")
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String   @default("general") // "factory" | "general"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pickupJobs           Job[]           @relation("PickupLocation")
  factoryJobs          Job[]           @relation("FactoryLocation")
  returnJobs           Job[]           @relation("ReturnLocation")
  rateTransferPickup   RateTransfer[]  @relation("RateTransferPickup")
  rateTransferReturn   RateTransfer[]  @relation("RateTransferReturn")
  rateIncomeFactory    RateIncome[]    @relation("RateIncomeFactory")
  rateDriverWageFactory RateDriverWage[] @relation("RateDriverWageFactory")

  @@index([name])
  @@index([type])
  @@map("locations")
}

model Job {
  id        String   @id @default(cuid())

  // Core fields
  jobDate           DateTime  @db.Date
  jobType           String
  customerId        String?
  customer          Customer?  @relation(fields: [customerId], references: [id])
  jobNumber         String    @unique
  driverId          String?
  driver            Driver?   @relation(fields: [driverId], references: [id])
  size              String?

  // Location fields
  pickupLocationId  String?
  pickupLocation    Location? @relation("PickupLocation", fields: [pickupLocationId], references: [id])
  factoryLocationId String?
  factoryLocation   Location? @relation("FactoryLocation", fields: [factoryLocationId], references: [id])
  returnLocationId  String?
  returnLocation    Location? @relation("ReturnLocation", fields: [returnLocationId], references: [id])

  // Financial fields
  income            Decimal?  @db.Decimal(10, 2)
  driverWage        Decimal?  @db.Decimal(10, 2)
  actualTransfer    Decimal?  @db.Decimal(10, 2)
  advance           Decimal?  @db.Decimal(10, 2)
  toll              Decimal?  @db.Decimal(10, 2)
  pickupFee         Decimal?  @db.Decimal(10, 2)
  returnFee         Decimal?  @db.Decimal(10, 2)
  liftFee           Decimal?  @db.Decimal(10, 2)
  storageFee        Decimal?  @db.Decimal(10, 2)
  tire              Decimal?  @db.Decimal(10, 2)
  other             Decimal?  @db.Decimal(10, 2)

  // Mileage & Fuel
  mileage           Int?
  fuelOfficeLiters  Decimal?  @db.Decimal(10, 2)
  fuelCashLiters    Decimal?  @db.Decimal(10, 2)
  fuelCashAmount    Decimal?  @db.Decimal(10, 2)
  fuelCreditLiters  Decimal?  @db.Decimal(10, 2)
  fuelCreditAmount  Decimal?  @db.Decimal(10, 2)

  // Status fields
  clearStatus       Boolean   @default(false)
  statementVerified Boolean   @default(false)

  // Metadata
  createdById String
  createdBy   AuthUser @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([jobDate])
  @@index([jobType])
  @@index([customerId])
  @@index([driverId])
  @@index([createdById])
  @@map("jobs")
}

// ==================== Rate Tables ====================

model RateTransfer {
  id               String   @id @default(cuid())
  jobType          String
  size             String
  pickupLocationId String
  returnLocationId String
  pickupFee        Decimal  @db.Decimal(10, 2)
  returnFee        Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pickupLocation Location @relation("RateTransferPickup", fields: [pickupLocationId], references: [id])
  returnLocation Location @relation("RateTransferReturn", fields: [returnLocationId], references: [id])

  @@unique([jobType, size, pickupLocationId, returnLocationId])
  @@map("rate_transfer")
}

model RateIncome {
  id                String   @id @default(cuid())
  jobType           String
  size              String
  factoryLocationId String
  customerId        String
  income            Decimal  @db.Decimal(10, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  factoryLocation  Location                  @relation("RateIncomeFactory", fields: [factoryLocationId], references: [id])
  customer         Customer                  @relation(fields: [customerId], references: [id])
  fuelSurcharges   RateIncomeFuelSurcharge[]

  @@unique([jobType, size, factoryLocationId, customerId])
  @@map("rate_income")
}

// ช่วงราคาน้ำมัน → surcharge เพิ่มจาก income ฐาน (ผูกกับ RateIncome แต่ละ record)
model RateIncomeFuelSurcharge {
  id           String  @id @default(cuid())
  rateIncomeId String
  fuelPriceMin Decimal @db.Decimal(10, 2) // ราคาน้ำมัน >= (บาท/ลิตร)
  fuelPriceMax Decimal @db.Decimal(10, 2) // ราคาน้ำมัน < (บาท/ลิตร)
  surcharge    Decimal @db.Decimal(10, 2) // ค่าเพิ่ม/ลด จากราคาฐาน

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rateIncome RateIncome @relation(fields: [rateIncomeId], references: [id], onDelete: Cascade)

  @@map("rate_income_fuel_surcharge")
}

// บันทึกราคาน้ำมัน รายวัน
model FuelPriceLog {
  id             String   @id @default(cuid())
  effectiveDate  DateTime @db.Date // วันที่มีผล
  pricePerLiter  Decimal  @db.Decimal(10, 2) // ราคา บาท/ลิตร
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([effectiveDate])
  @@index([effectiveDate])
  @@map("fuel_price_log")
}

model RateDriverWage {
  id                String   @id @default(cuid())
  jobType           String
  size              String
  factoryLocationId String
  driverWage        Decimal  @db.Decimal(10, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  factoryLocation Location @relation("RateDriverWageFactory", fields: [factoryLocationId], references: [id])

  @@unique([jobType, size, factoryLocationId])
  @@map("rate_driver_wage")
}

// ==================== LINE Bot Module ====================

model LineImage {
  id                String   @id @default(cuid())
  imageUrl          String
  senderId          String
  senderDisplayName String
  groupId           String
  groupName         String
  sentAt            DateTime
  messageId         String   @unique
  createdAt         DateTime @default(now())

  @@index([sentAt])
  @@index([senderId])
  @@index([groupId])
  @@map("line_images")
}
